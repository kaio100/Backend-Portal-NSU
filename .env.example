APP_NAME=nfse-backend
APP_VERSION=0.1.0
ENVIRONMENT=local

NFSE_AMBIENTE=producao
NFSE_VERIFY_SSL=true

DATABASE_URL=sqlite:///./data/nfse_backend.db

STORAGE_BACKEND=local
STORAGE_ROOT=storage
STORAGE_BUCKET=nfse

WORKER_DRY_RUN=false
WORKER_DRY_RUN_SLEEP=0.2
WORKER_REAL_MAX_LIMITE=1000
WORKER_REAL_MAX_PAUSA=0
WORKER_CONSULTA_LOTE_TAMANHO=1000
WORKER_TEMP_DIR=data/tmp_worker
API_WORKER_ENABLED=true
API_WORKER_SLEEP=0.2
API_WORKER_CONCURRENCY=1

CONSULTAS_SCHEDULER_SLEEP=1
CONSULTAS_DEFAULT_LIMITE=1000
CONSULTAS_DEFAULT_PAUSA=0
NOTAS_RECEBIDAS_DIA_CORTE_MES_ANTERIOR=3
DOWNLOAD_LOTE_MAX_NOTAS=1000

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

SECRETS_KEY=
